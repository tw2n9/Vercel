{
  "name": "app-barbearia-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend MVP para aplicativo de barbearia.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "test": "node --import tsx --test tests/scheduling-rules.test.ts",
    "build": "tsc",
    "deploy:build": "npm run build && npm run db:migrate && npm run db:seed-admin && npm run db:seed-services",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed-admin": "tsx src/database/seed-admin.ts",
    "db:seed-services": "tsx src/database/seed-services.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
